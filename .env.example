# Frontend Firebase config (required)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Baseline account bootstrap credentials (recommended)
VITE_DEFAULT_ADMIN_PASSWORD=
VITE_DEMO_VIEWER_USERNAME=demoakun
VITE_DEMO_VIEWER_PASSWORD=demo123456

# Server/automation Firebase config (required for scripts)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Cron auth fallback (optional if FIREBASE_SERVICE_ACCOUNT is used)
FIREBASE_CRON_EMAIL=
FIREBASE_CRON_PASSWORD=

# Optional integrations
SLACK_WEBHOOK_URL=
MONITORING_ENABLED=true
MONITORING_PAUSE_UNTIL=
MONITORING_QUOTA_GRACEFUL_EXIT=true
STATS_HEARTBEAT_HOURS=12

# Allowed Domain Whitelist (e.g. kendalkab.go.id)
VITE_ALLOWED_BASE_DOMAIN=kendalkab.go.id
ALLOWED_BASE_DOMAIN=kendalkab.go.id
