+
+  try {
+    await setDoc(userDocRef, {
+      appUserId: profile.appUserId,
+      username: profile.username,
+      email: profile.email || null,
+      role: profile.role,
+      permissions: profile.permissions,
+      isActive: profile.isActive,
+      updatedAt: Date.now(),
+    }, { merge: true })
+
+    return true
